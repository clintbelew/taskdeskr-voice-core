# ============================================================
# TaskDeskr Voice Core — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Application ───────────────────────────────────────────────────────────────
PORT=8000
DEBUG=false

# ── Vapi ──────────────────────────────────────────────────────────────────────
# Found in: Vapi Dashboard → Account → Webhook Secret
VAPI_WEBHOOK_SECRET=your_vapi_webhook_secret_here

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Optional — only required if using Claude
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ── LLM Routing ───────────────────────────────────────────────────────────────
# Options: "openai" | "anthropic" | "auto"
# "auto" routes summarization/analysis to Claude, conversations to GPT
DEFAULT_LLM_PROVIDER=openai

# ── GoHighLevel ───────────────────────────────────────────────────────────────
# Found in: GHL → Settings → Integrations → API Key
GHL_API_KEY=your_ghl_api_key_here

# Found in: GHL → Settings → Business Profile → Location ID
GHL_LOCATION_ID=your_ghl_location_id_here

# Found in: GHL → Calendars → [Your Calendar] → Settings → Calendar ID
GHL_CALENDAR_ID=your_ghl_calendar_id_here

# Optional: for pipeline opportunity creation
GHL_PIPELINE_ID=your_ghl_pipeline_id_here

# Timezone for appointment booking (IANA format)
GHL_TIMEZONE=America/Chicago

# ── Escalation ────────────────────────────────────────────────────────────────
# Phone number to transfer calls to when escalation is triggered (E.164 format)
ESCALATION_PHONE_NUMBER=+15125551234
